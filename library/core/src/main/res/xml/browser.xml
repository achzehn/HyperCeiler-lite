<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:quick_restart="com.android.browser">

    <PreferenceCategory android:title="@string/browser_settings">

        <SwitchPreference
            android:key="browser_disable_update_check"
            android:title="@string/browser_disable_update_check"
            android:summary="@string/browser_disable_update_check_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="browser_skip_splash"
            android:title="@string/browser_skip_splash"
            android:summary="@string/browser_skip_splash_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="browser_configuration"
            android:title="@string/browser_configuration"
            android:summary="@string/browser_configuration_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="browser_hide_homepage_top_bar"
            android:title="@string/browser_hide_homepage_top_bar"
            android:summary="@string/browser_hide_homepage_top_bar_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="browser_block_dialog"
            android:title="@string/browser_block_dialog"
            android:summary="@string/browser_block_dialog_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="browser_search_engine"
            android:title="@string/browser_search_engine"
            android:summary="@string/browser_search_engine_summary"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>
</PreferenceScreen>